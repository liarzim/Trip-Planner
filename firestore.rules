rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Trips Collection Rules
    match /trips/{tripId} {
      allow read, create, update, delete: if true;
    }

    // Groups Collection Rules
    match /groups/{groupId} {
      allow read, create, update, delete: if true;
    }

    // Events Collection Rules (Flight, Hotel, Waypoint)
    match /events/{eventId} {
      allow read, create, update, delete: if true;
    }

    // Expenses Collection Rules
    match /expenses/{expenseId} {
      allow read, create, update, delete: if true;
    }

    // Documents Collection Rules
    match /documents/{docId} {
      allow read, create, update, delete: if true;
    }

    // Packing Items Rules
    match /packingItems/{itemId} {
      allow read, create, update, delete: if true;
    }
  }
}
